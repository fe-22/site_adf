# Copie este arquivo para .env e preencha os valores antes de rodar localmente
# NÃO commite o arquivo .env no git

# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-segura-de-50-caracteres
DEBUG=False
ALLOWED_HOSTS=seu-dominio.run.app,localhost

# ─── Banco de Dados (PostgreSQL no Cloud SQL) ─────────────────────────────────
# Formato: postgresql://usuario:senha@host:5432/nome_do_banco
DATABASE_URL=postgresql://usuario:senha@/nome_do_banco?host=/cloudsql/projeto:regiao:instancia

# ─── Google Cloud Storage (para uploads de imagens / media) ───────────────────
# Deixe vazio para usar armazenamento local em desenvolvimento
GS_BUCKET_NAME=nome-do-seu-bucket
